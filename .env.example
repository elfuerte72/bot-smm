# Telegram
TELEGRAM_BOT_TOKEN=
OWNER_ID=
# Дополнительные пользователи, которым разрешено управлять ботом (CSV, опционально)
EXTRA_USER_IDS=
CHANNEL_ID=

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# Runtime
DB_PATH=./data/smm.db
LOG_LEVEL=INFO

# Web search / fetch
WEB_SEARCH_MAX_USES=5
WEB_SEARCH_COUNTRY=RU
WEB_FETCH_MAX_USES=3

# Cron (опционально). Время в формате HH:MM, CSV. Таймзона из IANA-базы.
CRON_TIMES=10:00,18:00
CRON_TZ=Europe/Moscow

# Mini App. Интервал снимка подписчиков канала в минутах (default 60 — 24 точки/сут).
CHANNEL_SNAPSHOT_INTERVAL_MINUTES=60
